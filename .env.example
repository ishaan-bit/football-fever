# ============================================================================
#  FOOTBALL FEVER — Environment Template
#  Copy to `.env.local` and fill in. EVERY value is optional: the app runs in
#  a fully-featured "demo mode" with bundled seed data when secrets are absent.
#  Add keys to progressively light up live data, auth, realtime and voice.
# ============================================================================

# ----------------------------------------------------------------------------
# World Cup 2026 data API  (https://github.com/rezarahiminia/worldcup2026)
# Without these, the app serves the bundled, accurate WC2026 seed dataset.
# ----------------------------------------------------------------------------
WORLDCUP_API_BASE_URL="https://worldcup26.ir"
# A long-lived JWT (84 days) obtained from POST /auth/authenticate.
WORLDCUP_API_TOKEN=""
# Optional auto-login if you don't want to paste a token:
WORLDCUP_API_EMAIL=""
WORLDCUP_API_PASSWORD=""
# Polling cadence (ms) for live score refresh on the server.
NEXT_PUBLIC_LIVE_POLL_MS="20000"

# ----------------------------------------------------------------------------
# Supabase — Auth, Postgres, Storage, Realtime, Presence
# Without these, auth uses a local guest profile and realtime is simulated.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# ----------------------------------------------------------------------------
# LiveKit — Voice rooms & group video watch-parties
# Without these, the call UI runs in a local mock (avatars, mute states).
# ----------------------------------------------------------------------------
NEXT_PUBLIC_LIVEKIT_URL=""        # wss://your-project.livekit.cloud
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# ----------------------------------------------------------------------------
# Upstash Redis — powers REAL live watch-party rooms (cross-device presence +
# chat, so people who join and their nicknames show up to everyone), plus
# leaderboards / rate limiting / live cache. Add the Upstash integration on
# Vercel (one click) to set both vars automatically.
# Without these, rooms fall back to the fully-simulated demo experience, and an
# in-memory store is used server-side (per-instance, non-persistent).
# ----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Dev/testing only: force real live rooms ON without Redis, using the in-memory
# store. Great for verifying presence + chat across two browser profiles in
# `next dev` (single process). Leave unset in production.
NEXT_PUBLIC_LIVE_ROOMS=""

# ----------------------------------------------------------------------------
# Anthropic (optional) — supercharges the AI host / Oracle commentary.
# Without it, the AI host uses the built-in deterministic personality engine
# (which never fabricates match events — it only reacts to verified data).
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Football Fever"
# Display timezone for kickoff times. IST is the default for our group.
NEXT_PUBLIC_DEFAULT_TZ="Asia/Kolkata"
