rules_version = '2';

// Football Fever is a play-money watch-party demo with guest (anonymous)
// identities — there is no Firebase Auth and no sensitive data. Reads are open
// so the room feels live; writes are open but shape/size-validated to curb
// abuse. If this ever grows real accounts, gate writes on request.auth.
service cloud.firestore {
  match /databases/{database}/documents {

    // Live presence for each room (heartbeat docs; deleted on leave).
    match /rooms/{roomId}/presence/{userId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60;
      allow delete: if true;
    }

    // Room chat.
    match /rooms/{roomId}/messages/{messageId} {
      allow read: if true;
      allow create, update: if request.resource.data.authorName is string
        && request.resource.data.authorName.size() <= 60
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 1200;
    }

    // Community roster (who has joined + nicknames).
    match /people/{userId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60;
    }

    // Scheduled match alerts + social pings.
    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update: if request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 500;
    }

    // Web Push subscriptions (device endpoints for app-closed OS alerts).
    // Sending still requires the server's VAPID private key, so exposure of an
    // endpoint alone does not let a third party push to it.
    match /pushSubs/{subId} {
      allow read: if true;
      allow create, update: if request.resource.data.endpoint is string
        && request.resource.data.endpoint.size() > 0
        && request.resource.data.endpoint.size() <= 1000
        && request.resource.data.keys is map;
      // The dispatcher prunes dead (410 Gone) subscriptions.
      allow delete: if true;
    }
  }
}
